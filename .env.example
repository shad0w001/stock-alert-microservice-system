# the secret for jwt token authentication
# needs to be a 32 bit string
JWT_SECRET=some_secret

# the exparation time for jwt tokens generated by the system
# value is in miliseconds
JWT_EXPIRATION=3600000

# this is the base url for the finnhub api
# this should be rather static
FINNHUB_API_BASE_URL=https://finnhub.io/api/v1

# this is an api key for the finnhub api
# you can get one from here:
# https://finnhub.io/dashboard
FINNHUB_API_KEY=your_api_key_here